# ──────────────────────────────────────────────────────────────────────
# Star Cars Wuppertal – Environment Variables
#
# Copy this file to .env.local and fill in the real values.
# Variables prefixed with VITE_ are exposed to the browser.
# ──────────────────────────────────────────────────────────────────────

# Base44 App ID (find it in the Base44 dashboard → Settings → App ID)
VITE_BASE44_APP_ID=your_app_id_here

# Base44 backend URL for this app (e.g. https://my-app-12345.base44.app)
VITE_BASE44_APP_BASE_URL=https://your-app.base44.app

# Optional: pin the Base44 functions version. Defaults to "v1".
# VITE_BASE44_FUNCTIONS_VERSION=v1
